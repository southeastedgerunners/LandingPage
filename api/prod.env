# Production env file for EdgeRunners API
# IMPORTANT: Do NOT commit this file. Add api/prod.env to .gitignore.

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production
# API listen URL (container should listen on 0.0.0.0:$PORT or a fixed port)
ASPNETCORE_URLS=http://0.0.0.0:5000

# CORS allowed origins - set the Netlify site and local dev origin
Cors__AllowedOrigins__0=https://southeastedgerunners.netlify.app
Cors__AllowedOrigins__1=http://localhost:5173

# n8n webhook URLs (replace with your production webhook URLs)
N8n__AvailabilityWebhookUrl=https://edgerunners.app.n8n.cloud/webhook/calendar-busy-times
N8n__BookingWebhookUrl=https://edgerunners.app.n8n.cloud/webhook/ac8233c5-8860-432f-bfab-50ea6b487524

# Optional logging override
# Logging__LogLevel__Default=Information
